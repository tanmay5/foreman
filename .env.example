# =============================================================================
# Foreman — environment configuration
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
FOREMAN_LLM_MODEL=claude-sonnet-4-6

# --- GitHub ---
# Personal Access Token (fine-grained recommended) with: repo (read), pull_request (read)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_HOST=api.github.com
GITHUB_USER=your-github-username

# --- Linear ---
# API key from: https://linear.app/settings/account/security
LINEAR_API_KEY=lin_api_your_key_here

# --- Jira ---
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_token_here

# --- Google Calendar (OAuth refresh token; setup flow lands in a future release) ---
GOOGLE_CALENDAR_TOKEN=

# --- Sentry ---
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=

# --- Slack ---
# Real Slack app with OAuth — see docs/slack-setup.md (NOT cookie scraping)
# Create at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_TEAM_ID=T0XXXXXXX
SLACK_USER_ID=U0XXXXXXX

# --- Scheduler ---
FOREMAN_BRIEFING_TIME=08:30
FOREMAN_BRIEFING_TIMEZONE=America/Los_Angeles
FOREMAN_PR_POLL_MINUTES=10
FOREMAN_JIRA_POLL_MINUTES=15
FOREMAN_SLACK_POLL_MINUTES=10

# --- Storage ---
# Defaults to platform-appropriate dir (e.g. ~/Library/Application Support/foreman on macOS)
# Override only if you want to pin location
# FOREMAN_DATA_DIR=/path/to/foreman/data

# --- Observability ---
FOREMAN_LOG_LEVEL=INFO
FOREMAN_DEBUG=false
